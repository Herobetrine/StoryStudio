{
  "name": "story-studio",
  "version": "0.7.0",
  "private": true,
  "description": "Local-first long-form webnovel writing workspace",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Herobetrine/StoryStudio.git"
  },
  "homepage": "https://github.com/Herobetrine/StoryStudio#readme",
  "bugs": {
    "url": "https://github.com/Herobetrine/StoryStudio/issues"
  },
  "scripts": {
    "start": "node server.js",
    "mock-provider": "node scripts/mock-provider-server.js",
    "test": "node --test --test-reporter=spec",
    "test:browser": "playwright test",
    "test:browser:install": "playwright install chromium",
    "check": "node scripts/check-js.js",
    "docs:check": "node scripts/check-docs.js",
    "quality:run": "node scripts/quality-regression-cli.js run",
    "quality:check": "node scripts/quality-regression-cli.js check",
    "quality:baseline": "node scripts/quality-regression-cli.js baseline --write fixtures/quality-regression-baseline-v1.json"
  },
  "files": [
    "server.js",
    "start-story-studio.ps1",
    "src/",
    "public/",
    "scripts/",
    "fixtures/quality-regression-v1.json",
    "fixtures/quality-regression-baseline-v1.json",
    "README.md",
    "ARCHITECTURE.md",
    "DESIGN.md",
    "ROADMAP.md",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "license": "AGPL-3.0-only",
  "dependencies": {
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "lucide-static": "^1.24.0",
    "minisearch": "^7.1.2",
    "write-file-atomic": "5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "supertest": "^7.2.2"
  }
}
